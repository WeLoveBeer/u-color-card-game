{
  "name": "u-color-card-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start:server": "node dist/server/src/main.js",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:api": "vitest run server/src/modules",
    "test:domain": "vitest run server/src/game/domain",
    "test:simulate": "vitest run server/src/game/domain/simulate"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  }
}
